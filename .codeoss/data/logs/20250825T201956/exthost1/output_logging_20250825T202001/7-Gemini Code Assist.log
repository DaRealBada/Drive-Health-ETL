app.listen(PORT, () =\u003e {\n  console.log(`Server running on port ${PORT}`);\n});"}]},"otherFiles":[{"filePath":"/home/tolubada1/package.json","includedReason":"RECENTLY_OPENED","segments":[{"content":"{\n  \"name\": \"simple-etl\",\n  \"version\": \"1.0.0\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"start\": \"node index.js\"\n  },\n  \"dependencies\": {\n    \"@google-cloud/bigquery\": \"^7.0.0\",\n    \"express\": \"^4.18.2\"\n  }\n}\n"}]}]},"metadata":{"ideName":"Code OSS for Cloud Shell","ideType":"CLOUD_SHELL","ideVersion":"1.100.3-cde","platform":"LINUX_AMD64","pluginType":"CLOUD_CODE","pluginVersion":"2.45.0"},"project":"cloudshell-gca","requestId":"cloudcode-794358504-df69da25-457f-4416-b6ea-2263165e5685","userContext":{}}
